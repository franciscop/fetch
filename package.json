{
  "name": "fch",
  "version": "5.1.5",
  "description": "Fetch interface with better promises, deduplication, defaults, etc.",
  "homepage": "https://github.com/franciscop/fetch",
  "repository": "https://github.com/franciscop/fetch.git",
  "bugs": "https://github.com/franciscop/fetch/issues",
  "funding": "https://www.paypal.me/franciscopresencia/19",
  "author": "Francisco Presencia <public@francisco.io> (https://francisco.io/)",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "esbuild src/index.ts --bundle --minify --sourcemap --outfile=index.min.js --format=esm",
    "build:types": "tsc --emitDeclarationOnly --outDir .",
    "typecheck": "tsc --noEmit",
    "size": "echo $(gzip -c index.min.js | wc -c) bytes",
    "start": "bun test --watch",
    "test": "npm run typecheck && bun test"
  },
  "keywords": [
    "fetch",
    "axios",
    "http",
    "https",
    "async",
    "ajax"
  ],
  "main": "index.min.js",
  "files": [
    "index.min.js",
    "index.d.ts",
    "index.min.js.map"
  ],
  "types": "index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "check-dts": "^0.9.0",
    "dotenv": "^16.3.1",
    "esbuild": "^0.19.2",
    "polystore": "^0.19.0",
    "redis": "^4.6.10"
  },
  "dependencies": {
    "swear": "^1.1.2"
  }
}
